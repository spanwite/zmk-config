ZMK_BEHAVIOR(m_type_email, macro,
    wait-ms = <0>;
    tap-ms = <5>;
    bindings = <
        &kp N &kp N3 &kp R &kp Q &kp N1 &kp N3 &kp N3 &kp N7
        &kp AT_SIGN
        &kp Y &kp A
        &kp DOT
        &kp R &kp U
    >;
)

// Windows sleep key
#define SLEEP_POWER &ht_sleep_power 0 0

ZMK_BEHAVIOR(ht_sleep_power, hold_tap,
    tapping-term-ms = <300>;
    bindings = <&m_win_sleep>, <&td_win_power>;
)

ZMK_BEHAVIOR(td_win_power, tap_dance,
    tapping-term-ms = <300>;
    bindings = <&none>, <&kp A>;
)

ZMK_BEHAVIOR(m_win_sleep, macro,
    wait-ms = <50>;
    tap-ms = <5>;
    bindings = <&kp LG(X) &kp U &kp S>;
)

#define MAKE_ALT_MACRO(NAME, KP_KEYS) \
    ZMK_BEHAVIOR(NAME, macro, \
        wait-ms = <0>; \
        tap-ms = <5>; \
        bindings \
        = <&macro_press   &kp LALT> \
        , <&macro_tap     KP_KEYS> \
        , <&macro_release &kp LALT> \
        ; \
    )

MAKE_ALT_MACRO(m_lbkt, &kp KP_N9 &kp KP_N1)
MAKE_ALT_MACRO(m_rbkt, &kp KP_N9 &kp KP_N3)