/*           42 KEY MATRIX / LAYOUT MAPPING

 ╭─────────────────────────┬─────────────────────────╮
 │ LT5 LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 RT5 │
 │ LM5 LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 RM5 │
 │ LB5 LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 RB5 │
 ╰───────────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────────╯
             ╰─────────────┴─────────────╯             */

// use require-prior-idle-ms for combos
#undef COMBO_HOOK
#define COMBO_HOOK require-prior-idle-ms = <150>;

#define COMBO_TERM_FAST 18
#define COMBO_TERM_SLOW 30

/* Horizontal combos - right hand */
ZMK_COMBO(lpar, &kp LPAR, RT1 RT2, QWERTY LSYM LNUM, COMBO_TERM_FAST)
ZMK_COMBO(rpar, &kp RPAR, RT2 RT3, QWERTY LSYM LNUM, COMBO_TERM_FAST)

ZMK_COMBO(lbrc, &kp LBRC, RM1 RM2, QWERTY LSYM LNUM, COMBO_TERM_FAST)
ZMK_COMBO(rbrc, &kp RBRC, RM2 RM3, QWERTY LSYM LNUM, COMBO_TERM_FAST)

ZMK_COMBO(lbkt, &m_lbkt, RB1 RB2, QWERTY LSYM LNUM, COMBO_TERM_FAST)
ZMK_COMBO(rbkt, &m_rbkt, RB2 RB3, QWERTY LSYM LNUM, COMBO_TERM_FAST)