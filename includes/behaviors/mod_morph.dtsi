// Reuse basic mod-morph scheme
#define SIMPLE_MORPH(NAME, MOD, BINDING1, BINDING2) \
    ZMK_BEHAVIOR(NAME, mod_morph, \
        mods = <(MOD_L ## MOD|MOD_R ## MOD)>; \
        bindings = <BINDING1>, <BINDING2>; \
    )


// Tap: Backspace | Shift-tap: Delete | Hold: activate layer "symbol"
ZMK_BEHAVIOR(bspc_del_lnav, mod_morph,
    bindings = <&lt LNAV BACKSPACE>, <&kp DELETE>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
)

 // Tap: Escape | LShift-tap: ~ | RShift-tap: ` | Hold: activate layer "symbol"
ZMK_BEHAVIOR(mm_gresc_lsym, mod_morph,
    bindings = <&lt LSYM ESCAPE>, <&kp GRAVE>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
    keep-mods = <(MOD_LSFT)>;
)

// Tap: Sticky Shift | Shift-tap: Caps Word | Double-tap: Caps Word | Hold: Shift
ZMK_BEHAVIOR(smart_shift, mod_morph,
    bindings = <&sk LSHIFT>, <&caps_word>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
)

// Tap: Space | Shift-tap: Dot -> Space -> Sticky Shift | Hold: activate layer "number"
// TODO: hold tap + tap dance
#define MACRO_SPACE &ht_space LNUM 0

ZMK_BEHAVIOR(ht_space, hold_tap,
    flavor = "balanced";
    tapping-term-ms = <200>;
    quick-tap-ms = <175>;
    bindings = <&mo>, <&spc_morph>;
)
SIMPLE_MORPH(spc_morph, SFT, &kp SPACE, &m_dot_spc)
// TODO: m_dot
ZMK_BEHAVIOR(m_dot_spc, macro,
    wait-ms = <0>;
    tap-ms = <10>;
    bindings = <&kp KP_DOT &kp SPACE &sk LSHFT>;
)

// Tap: Left bracket | Ctrl-tap: Right bracket
SIMPLE_MORPH(mm_lr_bkt, CTL, &kp LBKT, &kp RBKT)

// Tap: Sticky layer | Hold: Momentary layer
// Sticky Hold Layer | TODO: replace
ZMK_BEHAVIOR(shl, hold_tap,
    bindings = <&mo>, <&sk>;
    flavor = "balanced";
    tapping-term-ms = <200>;
)