/*           42 KEY MATRIX / LAYOUT MAPPING

 ╭─────────────────────────┬─────────────────────────╮
 │ LT5 LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 RT5 │
 │ LM5 LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 RM5 │
 │ LB5 LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 RB5 │
 ╰───────────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────────╯
             ╰─────────────┴─────────────╯             */

#undef COMBO_HOOK
#define COMBO_HOOK require-prior-idle-ms = <PRIOR_IDLE_TERM>;

#define COMBO_TERM 40

#define COMBO(NAME, KEYS, BINDINGS, LAYERS) \
    ZMK_COMBO(NAME, BINDINGS, KEYS, LAYERS, COMBO_TERM)


COMBO(esc,              LT2 LT1,      &kp ESC,               ALPHA NUMPAD CAPS_WORD)
COMBO(cut,              LT3 LT2,      &kp LC(X),             ALPHA NUMPAD CAPS_WORD)

COMBO(enter,            LM2 LM1,      &kp ENTER,             ALPHA NUMPAD CAPS_WORD)
COMBO(paste,            LM3 LM2,      &th_paste 0 0,         ALPHA NUMPAD CAPS_WORD)
COMBO(smart_numpad,     LM3 LM1,      &num_word,             ALPHA NUMPAD)

COMBO(copy,             LB3 LB2,      &th_copy 0 0,          ALPHA NUMPAD CAPS_WORD)
COMBO(l_change_lang,    LB2 LB1,      CHANGE_LANG,           ALPHA NUMPAD CAPS_WORD)

COMBO(l_delete,         LT3 LT2 LT1,  &kp DELETE,            ALPHA NUMPAD CAPS_WORD)
COMBO(l_bspc,           LM3 LM2 LM1,  &th_bspc 0 0,          ALPHA NUMPAD CAPS_WORD)
COMBO(l_tab,            LB3 LB2 LB1,  &th_tab 0 0,           ALPHA NUMPAD CAPS_WORD)

COMBO(undo,             LM2 LB3,      &kp LC(Z),             ALPHA NUMPAD CAPS_WORD)
COMBO(redo,             LM3 LB2,      &kp LC(LS(Z)),         ALPHA NUMPAD CAPS_WORD)
                    
COMBO(change_lang,      LM1 RM1,      CHANGE_LANG,           ALPHA NUMPAD CAPS_WORD)
COMBO(my_caps_word,     LM2 RM2,      &my_caps_word,         ALPHA NUMPAD)

COMBO(tab,              RM1 RM2,      &kp TAB,               ALPHA NUMPAD CAPS_WORD)
COMBO(bspc,             RM2 RM3,      &kp BSPC,              ALPHA NUMPAD CAPS_WORD)

COMBO(logic_or,         RB2 RB3,      &mc_logic_or,          LOWER RAISE SYMBOLS)
COMBO(triple_dot,       RB1 RB2,      &mc_triple_dot,        LOWER RAISE SYMBOLS)
COMBO(logic_and,        RM2 RM3,      &mc_logic_and,         LOWER RAISE SYMBOLS)
COMBO(nullish,          RM1 RM3,      &mc_nullish,           LOWER RAISE SYMBOLS)
COMBO(strict_eqls,      RM1 RM2,      &th_strict_eqls 0 0,   LOWER RAISE SYMBOLS)
COMBO(js_arrow_fn,      RT1 RT2,      &th_js_arrow_fn 0 0,   LOWER RAISE SYMBOLS)