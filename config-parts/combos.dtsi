/*           42 KEY MATRIX / LAYOUT MAPPING

 ╭─────────────────────────┬─────────────────────────╮
 │ LT5 LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 RT5 │
 │ LM5 LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 RM5 │
 │ LB5 LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 RB5 │
 ╰───────────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────────╯
             ╰─────────────┴─────────────╯             */

#undef COMBO_HOOK
#define COMBO_HOOK require-prior-idle-ms = <PRIOR_IDLE_TERM>;

#define COMBO_TERM 40

#define COMBO(NAME, KEYS, BINDINGS, LAYERS) \
    ZMK_COMBO(NAME, BINDINGS, KEYS, LAYERS, COMBO_TERM)

COMBO(select_all,       LT3 LT2,      &kp LC(A),             ALPHA NUMPAD CAPS_WORD)

COMBO(cut,              LT3 LT1,      &ht_cut 0 0,           ALPHA NUMPAD CAPS_WORD)
COMBO(paste,            LM3 LM2,      &ht_paste 0 0,         ALPHA NUMPAD CAPS_WORD)
COMBO(copy,             LM2 LM1,      &ht_copy 0 0,          ALPHA NUMPAD CAPS_WORD)
COMBO(win_paste,        LM3 LM2 LM1,  &kp LG(V),             ALPHA NUMPAD CAPS_WORD)

COMBO(smart_numpad,     LB3 LB2,      &num_word,             ALPHA NUMPAD)
COMBO(sl_powertoys,     LB2 LB1,      &sl POWERTOYS,         ALPHA NUMPAD CAPS_WORD)

COMBO(undo,             LM2 LB3,      &kp LC(Z),             ALPHA NUMPAD CAPS_WORD)
COMBO(redo,             LM3 LB2,      &kp LC(LS(Z)),         ALPHA NUMPAD CAPS_WORD)
                    
COMBO(change_language,  LM1 RM1,      CHANGE_LANG,           ALPHA NUMPAD CAPS_WORD)

COMBO(screenshot,       LM3 LM2,      &kp LS(LG(S)),         NAV)
COMBO(toggle_record,    LB3 LB2,      TOGGLE_RECORD,         NAV)
COMBO(toggle_overlay,   LB2 LB1,      TOGGLE_OVERLAY,        NAV)

COMBO(logic_or,         RB2 RB3,      &mc_logic_or,          NAV SYMBOLS)
COMBO(triple_dot,       RB1 RB2,      &mc_triple_dot,        NAV SYMBOLS)
COMBO(logic_and,        RM2 RM3,      &mc_logic_and,         NAV SYMBOLS)
COMBO(nullish,          RM1 RM3,      &mc_nullish,           NAV SYMBOLS)
COMBO(js_eqls,          RM1 RM2,      &ht_js_eqls 0 0,       NAV SYMBOLS)
COMBO(js_fn,            RT2 RT3,      &mc_js_fn,             NAV SYMBOLS)