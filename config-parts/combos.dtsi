/*           42 KEY MATRIX / LAYOUT MAPPING

 ╭─────────────────────────┬─────────────────────────╮
 │ LT5 LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 RT5 │
 │ LM5 LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 RM5 │
 │ LB5 LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 RB5 │
 ╰───────────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────────╯
             ╰─────────────┴─────────────╯             */

// Use require-prior-idle-ms for combos
#undef COMBO_HOOK
#define COMBO_HOOK require-prior-idle-ms = <150>;

/* Horizontal combos - left hand */
ZMK_COMBO(tab,      &kp TAB,        LT2 LT3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(del,      &kp DELETE,     LT1 LT2, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)

ZMK_COMBO(bspc,     &kp BSPC,       LM2 LM3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(cng_lng,  CNG_LNG,        LM1 LM2, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(mouse,    &smart_mouse,   LM3 LM1, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)

ZMK_COMBO(paste,    &kp LC(V),      LB1 LB2, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(copy,     &kp LC(C),      LB2 LB3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(cut,      &kp LC(X),      LB1 LB3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)

ZMK_COMBO(undo,     &kp LC(Z),      LM2 LB3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)
ZMK_COMBO(redo,     &kp LC(LS(Z)),  LM3 LB2, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_FAST)

/* Vertical combos - left hand */
ZMK_COMBO(l_esc,    &kp ESCAPE,     LT3 LM3, DEF NAV NUM_WORD NUM_EXPR,        COMBO_TERM_SLOW)

/* Horizontal combos - right hand */
ZMK_COMBO(cancel,   &kp K_CANCEL,   LT1 LM1, DEF NAV NUM_WORD NUM_EXPR MOUSE,  COMBO_TERM_FAST)

ZMK_COMBO(repeat,   &key_repeat,    LM2 LM3, DEF NAV NUM_WORD NUM_EXPR MOUSE,  COMBO_TERM_FAST)
ZMK_COMBO(esc,      &kp ESC,        LM1 LM2, DEF NAV NUM_WORD NUM_EXPR MOUSE,  COMBO_TERM_FAST)