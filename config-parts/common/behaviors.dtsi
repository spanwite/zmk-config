#define HOME_ROW_MOD(NAME, HOLD, TAP, TRIGGER_POS) \
    ZMK_BEHAVIOR(NAME, hold_tap, \
        flavor = "balanced"; \
        tapping-term-ms = <280>; \
        quick-tap-ms = <QUICK_TAP_TERM>; \
        require-prior-idle-ms = <150>; \
        bindings = <HOLD>, <TAP>; \
        hold-trigger-key-positions = <TRIGGER_POS>; \
        hold-trigger-on-release; \
    )

HOME_ROW_MOD(hml, &kp, &kp, KEYS_R KEYS_T)
HOME_ROW_MOD(hmr, &kp, &kp, KEYS_L KEYS_T)

ZMK_BEHAVIOR(my_caps_word, caps_word,
    layers = <CAPS_WORD>;
    continue-list = <UNDERSCORE MINUS BACKSPACE DELETE SQT GRAVE LBKT RBKT DOT COMMA LEFT DOWN UP RIGHT>;
    ignore-alphas;
    ignore-modifiers;
)

