#define MAKE_HRM(NAME, TRIGGER_POS) \
    ZMK_BEHAVIOR(NAME, hold_tap, \
        flavor = "balanced"; \
        tapping-term-ms = <280>; \
        quick-tap-ms = <QUICK_TAP_MS>; \
        require-prior-idle-ms = <150>; \
        bindings = <&kp>, <&kp>; \
        hold-trigger-key-positions = <TRIGGER_POS>; \
        hold-trigger-on-release; \
    )

MAKE_HRM(hml, KEYS_R KEYS_T)
MAKE_HRM(hmr, KEYS_L KEYS_T)

SIMPLE_MORPH(mm_excl, SFT, &kp EXCL, &m_end_excl)
SIMPLE_MORPH(mm_qst, SFT, &m_qst, &m_end_qst)
SIMPLE_MORPH(mm_at_email, SFT, &kp AT_SIGN, &m_type_email)

ZMK_BEHAVIOR(num_expr, caps_word,
    layers = <NUM_EXPR>;
    continue-list = <
        PLUS MINUS STAR KP_DIVIDE EQUAL PERCENT LPAR RPAR 
        SPACE BACKSPACE DELETE
        KP_N0 KP_N1 KP_N2 KP_N3 KP_N4 KP_N5 KP_N6 KP_N7 KP_N8 KP_N9
    >;
    ignore-numbers;
    ignore-modifiers;
)

