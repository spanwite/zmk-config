#define ZOOM_IN      &kp LC(EQUAL)
#define ZOOM_OUT     &kp LC(MINUS)

#define NAV_LEFT     &mt HOME     LEFT
#define NAV_RIGHT    &mt END      RIGHT
#define NAV_UP       &mt LC(HOME) UP
#define NAV_DOWN     &mt LC(END)  DOWN

ZMK_LAYER(nav,
// ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────╮   ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────╮
     ___                ___                &kp LC(DEL)        &kp DEL            &kp ESC            ___                    ___                &kp INS            &kp PG_DN          &kp PG_UP          ___                ___
// ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
     ___                ___                &hml LALT LC(BSPC) &hml LCTRL BSPC    &hml LCTRL ENTER   ___                    NAV_LEFT           NAV_DOWN           NAV_UP             NAV_RIGHT          ___                ___
// ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
     ___                ___                ZOOM_OUT           ZOOM_IN            &kp TAB            ___                    ___                ___                &kp LC(LEFT)       &kp LC(RIGHT)      ___                ___
// ╰──────────────────┴──────────────────┴──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┴──────────────────┴──────────────────╯
                                                              ___                ___                ___                    ___                &kp UNDER          ___ 
//                                                          ╰──────────────────┴──────────────────┴──────────────────╯   ╰──────────────────┴──────────────────┴──────────────────╯
)