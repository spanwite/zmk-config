#define ZOOM_IN      &kp LC(EQUAL)
#define ZOOM_OUT     &kp LC(MINUS)

#define NAV_LEFT     &mt HOME     LEFT
#define NAV_RIGHT    &mt END      RIGHT
#define NAV_UP       &mt LC(HOME) UP
#define NAV_DOWN     &mt LC(END)  DOWN

ZMK_LAYER(nav,
// ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────╮   ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────┬──────────────────╮
     ___                ___                &kp LS(TAB)        &ts_swapper        &kp ESC            ___                    ___                ___                &kp DEL            &kp LC(DEL)        ___                ___
// ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
     ___                &kp LGUI           &hml LALT LC(BSPC) &hml LCTRL BSPC    &kp ENTER          ___                    NAV_LEFT           NAV_DOWN           NAV_UP             NAV_RIGHT          ___                ___
// ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┼──────────────────┼──────────────────┤
     ___                ___                ZOOM_OUT           ZOOM_IN            &kp TAB            ___                    ___                &kp INS            &kp PG_DN          &kp PG_UP          ___                ___
// ╰──────────────────┴──────────────────┴──────────────────┼──────────────────┼──────────────────┼──────────────────┤   ├──────────────────├──────────────────┼──────────────────┼──────────────────┴──────────────────┴──────────────────╯
                                                              ___                ___                ___                    ___                &kp UNDER          ___ 
//                                                          ╰──────────────────┴──────────────────┴──────────────────╯   ╰──────────────────┴──────────────────┴──────────────────╯
)

ZMK_BEHAVIOR(ts_swapper, tri_state,
    bindings = <&kt LALT>, <&kp TAB>, <&kt LALT>;
    ignored-key-positions = <LT3>;
)