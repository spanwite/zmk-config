// Homerow mods
MAKE_HRM(hml, KEYS_R KEYS_T)
MAKE_HRM(hmr, KEYS_L KEYS_T)

// Tap: Escape | LShift-tap: ~ | RShift-tap: `
ZMK_BEHAVIOR(mm_gresc, mod_morph,
    bindings = <&kp ESCAPE>, <&kp GRAVE>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
    keep-mods = <(MOD_LSFT)>;
)

// Tap: Left bracket | Ctrl-tap: Right bracket
SIMPLE_MORPH(mm_lr_bkt, CTL, &kp LBKT, &kp RBKT)

// Tap Dance profile management
ZMK_BEHAVIOR(td_profiles, tap_dance,
    bindings = <&tog MEDIA>, <&tog GAME_FPS>;
)

// Tap: None | Double-tap: CapsLock
ZMK_BEHAVIOR(td_capslock, tap_dance,
    bindings = <&none>, <&kp CAPSLOCK>;
)

// Tap: Dot | Hold: Layer FN
ZMK_BEHAVIOR(ht_mdot_l, hold_tap,
    bindings = <&mo>, <&m_dot>;
    tapping-term-ms = <300>;
    quick-tap-ms = <200>;
    flavor = "balanced";
)