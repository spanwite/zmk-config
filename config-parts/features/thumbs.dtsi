LAYERTAP_KEY(lt_spc, &mm_spc_triple_under)

MORPH_SINGLE(mm_spc_dot,          LSFT, &kp SPACE,     &mc_end_dot)
MORPH_SINGLE(mm_spc_under,        RSFT, &mm_spc_dot,   &kp UNDERSCORE)
MORPH_SINGLE(mm_spc_triple_under, RCTL, &mm_spc_under, &mc_triple_under)

