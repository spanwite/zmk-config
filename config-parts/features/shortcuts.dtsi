MACRO_0_MS(mc_copy,           &kp LC(C))
MACRO_0_MS(mc_sel_copy,       &kp LC(A) &kp LC(C))
HOLDTAP_KEY(ht_copy,          &mc_sel_copy, &mc_copy)

MACRO_0_MS(mc_paste,          &kp LC(V))
MACRO_0_MS(mc_sel_paste,      &kp LC(A) &kp LC(V))
HOLDTAP_KEY(ht_paste,         &mc_sel_paste, &mc_paste)

MACRO_0_MS(mc_cut,            &kp LC(X))
MACRO_0_MS(mc_sel_cut,        &kp LC(A) &kp LC(X))
HOLDTAP_KEY(ht_cut,           &mc_sel_cut, &mc_cut)

MORPH_SINGLE(mm_caps_word, LSFT, &my_caps_word, &to CAPS_WORD)

MACRO_0_MS(mc_win_emoji,      &kp LG(DOT))
MACRO_10_MS(mc_emoji_lng,     &kp ESC CHANGE_LANG &kp LG(DOT))
HOLDTAP_KEY(ht_win_emoji,     &mc_emoji_lng, &mc_win_emoji)

MACRO_0_MS(mc_close_others,   CLOSE_OTHERS)
MACRO_0_MS(mc_close_right,    CLOSE_RIGHT)
HOLDTAP_KEY(ht_close_tab,     &mc_close_right, &mc_close_others)