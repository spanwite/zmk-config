#define MAKE_HRM(NAME, HOLD, TAP, TRIGGER_POS) \
    ZMK_HOLD_TAP(NAME, \
        flavor = "balanced"; \
        tapping-term-ms = <280>; \
        quick-tap-ms = <QUICK_TAP_MS>; \
        require-prior-idle-ms = <150>; \
        bindings = <HOLD>, <TAP>; \
        hold-trigger-key-positions = <TRIGGER_POS>; \
        hold-trigger-on-release; \
    )

#define HRM_LEFT(NAME, HOLD, TAP) \
    MAKE_HRM(hml, HOLD, TAP, KEYS_R KEYS_T)

#define HRM_RIGHT(NAME, HOLD, TAP) \
    MAKE_HRM(hmr, HOLD, TAP, KEYS_L KEYS_T)